# Database (SQLite — points to local file)
DATABASE_URL="file:./prisma/dev.db"

# Encryption key for API keys stored in SQLite (change this to any random string)
ENCRYPTION_KEY="change-me-to-a-random-string"

# The app reads LLM config from the Settings UI.
# You only need to set this if you want to pre-seed it.
# LLM_PROVIDER=claude
# LLM_MODEL=claude-sonnet-4-6
# LLM_API_KEY=your-api-key-here
